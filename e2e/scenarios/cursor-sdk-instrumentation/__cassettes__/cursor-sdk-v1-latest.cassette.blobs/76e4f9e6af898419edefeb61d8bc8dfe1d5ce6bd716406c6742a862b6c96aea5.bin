{"config":"{\"can_record_session\":true,\"dynamic_configs\":{\"3364382\":{\"group\":\"inlineTargetingRules\",\"id_type\":\"userID\",\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false,\"name\":\"3364382\",\"rule_id\":\"inlineTargetingRules\",\"secondary_exposures\":[{\"gate\":\"3110400444\",\"gateValue\":\"false\",\"ruleID\":\"174cKR8Q5lFaSsg1XvacBQ:10.00:1\"}],\"value\":{}},\"10779917\":{\"group\":\"default\",\"id_type\":\"teamID\",\"is_device_based\":false,\"name\":\"10779917\",\"passed\":false,\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"enabled\":false}},\"12925753\":{\"group\":\"default\",\"id_type\":\"userID\",\"is_device_based\":false,\"name\":\"12925753\",\"passed\":false,\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"lifecycle\":\"default-off\"}},\"19843277\":{\"group\":\"default\",\"id_type\":\"userID\",\"is_device_based\":false,\"name\":\"19843277\",\"passed\":false,\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"startup_tips\":[{\"id\":\"cloud-subagents\",\"text\":\"Use /in-cloud for cloud subagents\"}]}},\"20554329\":{\"group\":\"launchedGroup\",\"group_name\":\"Test\",\"id_type\":\"userID\",\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false,\"name\":\"20554329\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"value\":{\"enabled\":true}},\"28154653\":{\"group\":\"default\",\"id_type\":\"userID\",\"is_device_based\":false,\"name\":\"28154653\",\"passed\":false,\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{}},\"28662324\":{\"group\":\"launchedGroup\",\"group_name\":\"Control\",\"id_type\":\"userID\",\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false,\"name\":\"28662324\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"value\":{\"group\":\"control\"}},\"29811531\":{\"group\":\"default\",\"id_type\":\"userID\",\"is_device_based\":false,\"name\":\"29811531\",\"passed\":false,\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"rolesToItems\":{\"Data\":[{\"pluginKey\":\"databricks\",\"prompt\":\"I want to answer a question with our warehouse data. Start by listing the schemas and tables so you know what's available, then ask me what question to dig into. Or if you spot an obviously interesting table, propose a question and answer it with a query I can read.\",\"subtitle\":\"Answer a business question straight from the warehouse\",\"title\":\"Query the warehouse\"},{\"pluginKey\":\"github\",\"prompt\":\"Pick an important-looking metric defined in this repo and trace how it's built, from raw tables to the final number. Show the source tables, transformation steps, key assumptions, and where the metric is defined or used. If anything is ambiguous, call it out and suggest what to verify next.\",\"subtitle\":\"Trace a metric from raw tables to final number\",\"title\":\"Trace a metric\"},{\"pluginKey\":\"hex\",\"prompt\":\"Help me turn a question into a Hex notebook: the query, a clean chart, and one sentence on what it shows. Ask me what question to start with, or propose one based on what's in the workspace.\",\"subtitle\":\"Build a chart from a metric question\",\"title\":\"Chart a question\"},{\"pluginKey\":\"notion\",\"prompt\":\"Turn this analysis into a decision-ready brief. Include the business question, method, key findings, caveats, recommendation, and next steps. Call out any assumptions or limitations that could change the decision.\",\"subtitle\":\"Summarize an analysis into findings and recommendations\",\"title\":\"Write up findings\"},{\"pluginKey\":\"jira\",\"prompt\":\"Find the data request tickets assigned to me in Jira, pick the top one, and break it into an analysis plan: the clarifying questions I should ask, the tables and queries it needs, and what the deliverable should look like. If nothing's assigned to me, grab a recent request from the team queue.\",\"subtitle\":\"Turn a data request into queries and an analysis plan\",\"title\":\"Plan a data request\"}],\"Designer\":[{\"pluginKey\":\"figma\",\"prompt\":\"I want to turn one of my Figma designs into working code. Ask me to paste a link to the frame (or tell me to select it in Figma), then build it faithfully: real layout, real spacing, real text. Show me how to open it in the browser when you're done.\",\"subtitle\":\"Turn a design frame into working, clickable code\",\"title\":\"Design to code\"},{\"pluginKey\":\"vercel\",\"prompt\":\"Take the prototype we've been working on and deploy it to Vercel so I get a live URL I can share for feedback. Walk me through any login step, and give me the link when it's up.\",\"subtitle\":\"Put the prototype at a live link anyone can open\",\"title\":\"Publish a prototype\"},{\"pluginKey\":\"linear\",\"prompt\":\"Take my rough handoff notes and turn them into clear, scoped Linear tickets: what to build, the states and edge cases, and what \\\"done\\\" looks like. I'll paste the notes, or point you at existing tickets to clean up.\",\"subtitle\":\"Turn handoff notes into tickets engineers can pick up\",\"title\":\"Notes to tickets\"},{\"pluginKey\":\"notion\",\"prompt\":\"Search my Notion for recent design critique or feedback notes, and turn them into a short decision doc: what was decided, what's still open, and the next steps with owners. Keep it to one page.\",\"subtitle\":\"Turn design feedback into decisions and next steps\",\"title\":\"Feedback to decisions\"}],\"Educator\":[{\"pluginKey\":\"notion\",\"prompt\":\"Help me plan a lesson. Ask me the topic and level, then draft lecture notes, two worked examples, and three exercises with an answer key, saved as a doc I can edit.\",\"subtitle\":\"Build a lesson plan with examples and exercises\",\"title\":\"Plan a lesson\"},{\"pluginKey\":\"github\",\"prompt\":\"Look across the student repos in this org (or the ones I point you at), find the common issues, and draft short, encouraging feedback for each: one thing done well, the main thing to fix, and how.\",\"subtitle\":\"Review student repos and draft feedback\",\"title\":\"Review student repos\"},{\"pluginKey\":\"context7\",\"prompt\":\"Help me create a programming assignment: ask me the topic and level, then generate starter code, hidden tests, and a rubric, using current library versions so nothing is deprecated by the time students run it.\",\"subtitle\":\"Create an assignment with starter code and tests\",\"title\":\"Create an assignment\"},{\"pluginKey\":\"vercel\",\"prompt\":\"Help me build a small interactive demo that teaches one concept from my class, and deploy it to a link students can open on their phones. Ask me which concept.\",\"subtitle\":\"Build a live demo for a class concept\",\"title\":\"Build a class demo\"}],\"Other...\":[{\"pluginKey\":\"github\",\"prompt\":\"Give me a tour of this repo: the architecture, the main flows, and how to run it locally. Then propose three small, safe tasks I could ship this week, with the files each one touches.\",\"subtitle\":\"Explain the repo and suggest three starter tasks\",\"title\":\"Tour the repo\"},{\"pluginKey\":\"jira\",\"prompt\":\"Find the Jira tickets assigned to me, pick the one that best fits this repo, and turn it into a step-by-step implementation plan: the approach, the files to change, and how to test it. If nothing is assigned to me, suggest three small open tickets and recommend one to start with.\",\"subtitle\":\"Pick up a ticket and plan the fix in this repo\",\"title\":\"Plan a ticket\"},{\"pluginKey\":\"datadog\",\"prompt\":\"Pull the most frequent production errors from the last 24 hours, group them by likely root cause, and trace the top one to the code in this repo that throws it. Tell me what you'd check or fix first. If it's quiet, summarize overall service health instead.\",\"subtitle\":\"Find the top production errors and where they start in the code\",\"title\":\"Investigate errors\"},{\"pluginKey\":\"slack\",\"prompt\":\"Summarize my unread mentions and the threads where someone is waiting on me. For anything code-related, point me to the relevant part of this repo, and draft a short reply I can edit for the two most urgent ones.\",\"subtitle\":\"Catch up on mentions and threads waiting on a reply\",\"title\":\"Catch up on Slack\"}],\"Product Manager\":[{\"pluginKey\":\"jira\",\"prompt\":\"Find active projects in the connected workspace, pick the one with the most recent activity, and draft a one-page product spec from its issues and docs: the problem, requirements, open questions, and anything ambiguous or contradictory. Flag assumptions the project relies on but never states.\",\"subtitle\":\"Draft a product spec from an active project\",\"title\":\"Draft a spec\"},{\"pluginKey\":\"amplitude\",\"prompt\":\"Look at recent usage in Amplitude and summarize adoption and drop-off for a feature: who's picking it up, where people fall out of the flow, and how that changed over the last 30 days. Ask me which feature to look at, or if one stands out in the data, start there and tell me why.\",\"subtitle\":\"Summarize adoption and drop-off for a feature\",\"title\":\"Analyze usage\"},{\"pluginKey\":\"github\",\"prompt\":\"Read this repo and explain the product in plain language: the main user flows, where each one lives in the code, and what looks easy versus hard to change. I'm a PM, not an engineer, so skip the jargon and give me the mental model.\",\"subtitle\":\"Explain how the product works from the codebase\",\"title\":\"Understand the product\"},{\"pluginKey\":\"notion\",\"prompt\":\"Search my Notion workspace for customer feedback, research notes, and meeting notes from the last quarter. Synthesize them into ranked themes with rough frequency, and draft a short problem brief for the top theme. Cite which notes each theme came from.\",\"subtitle\":\"Turn scattered feedback into ranked product themes\",\"title\":\"Synthesize feedback\"},{\"pluginKey\":\"figma\",\"prompt\":\"I want to turn a Figma mock into a clickable prototype I can share. Ask me to paste a link to the frame, then build it as a working page and tell me how to view it in the browser.\",\"subtitle\":\"Turn a mock into a clickable prototype\",\"title\":\"Prototype a mock\"}],\"Researcher\":[{\"pluginKey\":\"notion\",\"prompt\":\"Search my Notion for reading notes and research materials, and synthesize them into a structured summary: the main themes, where sources agree and disagree, and the open questions worth pursuing. Cite which note each claim comes from.\",\"subtitle\":\"Synthesize saved readings into themes and findings\",\"title\":\"Synthesize readings\"},{\"pluginKey\":\"github\",\"prompt\":\"Reproduce the results from this analysis repo. Set up the environment, install dependencies, run the main analysis, and compare the outputs to the README or paper. Document the exact steps, any deviations, and anything that prevents a faithful reproduction.\",\"subtitle\":\"Reproduce results from an analysis repo\",\"title\":\"Reproduce results\"},{\"pluginKey\":\"hex\",\"prompt\":\"Help me explore a dataset in a Hex notebook: profile what's in it, run the analysis that best answers my question, and produce a publication-clean figure. Ask me which dataset and question to start with.\",\"subtitle\":\"Explore a dataset and chart the key result\",\"title\":\"Explore a dataset\"}],\"Software Engineer\":[{\"pluginKey\":\"github\",\"prompt\":\"Give me a tour of this repo: the architecture, the main flows, and how to run it locally. Then propose three small, safe tasks I could ship this week, with the files each one touches.\",\"subtitle\":\"Explain the repo and suggest three starter tasks\",\"title\":\"Tour the repo\"},{\"pluginKey\":\"jira\",\"prompt\":\"Find the tickets assigned to me and pick one that fits this repo. Turn it into a step-by-step implementation plan with the approach, files to change, and tests to run. If nothing is assigned to me, suggest three small open tickets that fit this repo and recommend one to start with.\",\"subtitle\":\"Pick a ticket and plan the fix in this repo\",\"title\":\"Plan a ticket\"},{\"pluginKey\":\"datadog\",\"prompt\":\"Pull the most frequent production errors from the last 24 hours, group them by likely root cause, and trace the top one to the code in this repo that throws it. Tell me what you'd check or fix first. If it's quiet, summarize overall service health instead.\",\"subtitle\":\"Find the top production errors and where they start in the code\",\"title\":\"Investigate errors\"},{\"pluginKey\":\"slack\",\"prompt\":\"Summarize my unread mentions and the threads where someone is waiting on me. For anything code-related, point me to the relevant part of this repo, and draft a short reply I can edit for the two most urgent ones.\",\"subtitle\":\"Catch up on mentions and threads waiting on a reply\",\"title\":\"Catch up on Slack\"},{\"pluginKey\":\"supabase\",\"prompt\":\"Use the connected Supabase project and this repo to review the database design. Explain how the main tables relate, check for missing indexes, risky RLS policies, and schema patterns that could cause bugs or slow queries. Suggest the top three improvements and include the SQL or migration I should review before applying.\",\"subtitle\":\"Review the database schema for performance and security issues\",\"title\":\"Review your schema\"}],\"Student\":[{\"pluginKey\":\"vercel\",\"prompt\":\"Help build a simple web app and deploy it with a real URL to share. Ask what to make, or suggest three fun ideas that could be finished today. Then build it, deploy it, and provide the live link.\",\"subtitle\":\"Build a web app and publish it live\",\"title\":\"Build & publish\"},{\"pluginKey\":\"github\",\"prompt\":\"Look at this project like a helpful TA: what works, what's broken or missing, and what I should finish or fix first. Give me a short prioritized list, and explain the top item like I'm seeing it for the first time.\",\"subtitle\":\"Review a class project and suggest next steps\",\"title\":\"Review my project\"},{\"pluginKey\":\"context7\",\"prompt\":\"I'll paste an error I'm stuck on (or find one in this project). Fix it using current documentation for the library involved, then explain what actually went wrong in plain language, like a patient tutor. I want to understand it, not just make it go away.\",\"subtitle\":\"Debug an error and explain why it happened\",\"title\":\"Debug an error\"},{\"pluginKey\":\"notion\",\"prompt\":\"Search my Notion for class notes on a topic (ask me which), and turn them into a study guide: the key concepts in plain language, five practice problems from easy to hard, and a plan for the week before the exam.\",\"subtitle\":\"Turn notes into a study guide and practice plan\",\"title\":\"Make a study guide\"}],\"default\":[{\"pluginKey\":\"github\",\"prompt\":\"Give me a tour of this repo: the architecture, the main flows, and how to run it locally. Then propose three small, safe tasks I could ship this week, with the files each one touches.\",\"subtitle\":\"Explain the repo and suggest three starter tasks\",\"title\":\"Tour the repo\"},{\"pluginKey\":\"notion\",\"prompt\":\"Search my Notion workspace for recent notes and docs, and synthesize them into a short summary with the main themes and next steps. Cite which notes each point came from.\",\"subtitle\":\"Synthesize your recent notes and docs\",\"title\":\"Search your notes\"},{\"pluginKey\":\"linear\",\"prompt\":\"Find the issues assigned to me in Linear, pick one to start, and turn it into a step-by-step plan. If nothing's assigned to me, suggest a few open issues and recommend one to start with.\",\"subtitle\":\"Connect Linear and start on an issue\",\"title\":\"Start an issue\"}]}}},\"38710384\":{\"group\":\"prestart\",\"id_type\":\"userID\",\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false,\"name\":\"38710384\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"value\":{}},\"79934572\":{