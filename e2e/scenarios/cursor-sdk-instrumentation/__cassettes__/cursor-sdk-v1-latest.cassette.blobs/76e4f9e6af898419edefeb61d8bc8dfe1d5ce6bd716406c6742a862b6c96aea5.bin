tings\",\"url\":\"cursor://anysphere.cursor-deeplink/settings/mcp\"},\"id\":\"mcp\",\"targetSurfaces\":[\"editor\",\"glass\"],\"text\":\"Configure MCPs in your Cursor Settings to give agents access to tools and data\"},{\"action\":{\"kind\":\"link\",\"label\":\"cursor.com/agents\",\"url\":\"https://cursor.com/agents\"},\"id\":\"cloud-agents\",\"targetSurfaces\":[\"editor\"],\"text\":\"Use cloud agents for better parallelization and durable execution at cursor.com/agents\"},{\"action\":{\"kind\":\"link\",\"label\":\"cursor.com/automations\",\"url\":\"https://cursor.com/automations\"},\"id\":\"automations-editor\",\"targetSurfaces\":[\"editor\"],\"text\":\"Set up automations to automate tasks and save time at cursor.com/automations\"},{\"action\":{\"kind\":\"deeplink\",\"label\":\"automations\",\"url\":\"cursor://anysphere.cursor-deeplink/automations\"},\"id\":\"automations-glass\",\"targetSurfaces\":[\"editor\",\"glass\"],\"text\":\"Use automations to save time on repetitive tasks with always-on agents\"},{\"action\":{\"kind\":\"prompt\",\"label\":\"/loop\",\"text\":\"/loop: do this task every hour - \"},\"id\":\"loop\",\"targetSurfaces\":[\"glass\"],\"text\":\"Use /loop to run a prompt on a schedule\"},{\"action\":{\"kind\":\"prompt\",\"label\":\"/automate\",\"text\":\"/automate this workflow: \"},\"id\":\"automate\",\"targetSurfaces\":[\"editor\",\"glass\"],\"text\":\"Use /automate to create Cursor Automations without leaving your agent chat\"},{\"action\":{\"commandId\":\"glass.openModelPicker\",\"kind\":\"command\",\"label\":\"model picker\"},\"id\":\"composer-balance\",\"targetSurfaces\":[\"editor\",\"glass\"],\"text\":\"Select Composer in your model picker for a great balance of intelligence and cost\"},{\"action\":{\"kind\":\"prompt\",\"label\":\"/best-of-N\",\"text\":\"Use /best-of-N to compare models on this task: \"},\"id\":\"best-of-n\",\"targetSurfaces\":[\"editor\"],\"text\":\"Use /best-of-N to compare how different models perform on the same task\"},{\"